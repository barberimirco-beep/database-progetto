# ══════════════════════════════════════════════════════════════
#  File .env — Variabili d'ambiente per il progetto RFID
#  ⚠️  NON caricare questo file su GitHub (aggiungilo a .gitignore)
# ══════════════════════════════════════════════════════════════

# ── MySQL: utente root (usato solo internamente da MySQL) ─────
# Password dell'account root del server MySQL.
# Deve essere lunga e complessa in produzione.
MYSQL_ROOT_PASSWORD=RootPassword_Sicura_2024!

# ── MySQL: nome del database dell'applicazione ────────────────
# Il nome dello schema che verrà creato automaticamente al primo avvio.
MYSQL_DATABASE=rfid_db

# ── MySQL: utente applicativo (NON root) ──────────────────────
# L'applicazione PHP si connette con questo utente, non con root.
# Principio del minimo privilegio: ha solo i permessi necessari.
MYSQL_USER=rfid_user

# ── MySQL: password dell'utente applicativo ───────────────────
# Cambia questa stringa con una password robusta prima del deploy.
MYSQL_PASSWORD=RfidPassword_2024!

# ── Porta esposta sull'host ───────────────────────────────────
# La porta su cui il server scolastico risponderà alle richieste HTTP.
# Corrisponde al valore richiesto dal docente/amministratore.
APP_PORT=10044
